      "function_name": "adsGenerateCampaign2026",
      "description": "Genera una campa\u00f1a Google Ads COMPLETA y profesional (Search AI Max / Shopping / Performance Max / Demand Gen) con copy, keywords, asset groups, audiencias, brand safety y forecast. Params: {operation_brief (el AI Brief en lenguaje natural), campaign_type, audience, objective, daily_budget_clp, landing_url, codename, generate_visuals (bool, solo PMax/Demand Gen), num_visuals}. Devuelve draft_id."
    },
    {
      "function_name": "adsExportEditor",
      "description": "Exporta un AdCampaignDraft a CSV compatible con Google Ads Editor (subida masiva 1-click). Param: {draft_id}. Devuelve file_url del CSV."
    },
    {
      "function_name": "adsForecastPerformance",
      "description": "Proyecta KPIs DETERMINISTAS (impresiones, CTR, conversiones, CAC, ROAS) de un draft antes de lanzarlo, calculados sobre la estructura real del draft y el AOV B2C real del cat\u00e1logo, con veredicto. Param: {draft_id}."
    },
    {
      "function_name": "adsAnalyzePerformance",
      "description": "Analiza el rendimiento real de una campa\u00f1a en vivo y emite veredicto WINNER/LOSER/INCONCLUSO con recomendaciones. Si no le pasas m\u00e9tricas, lee autom\u00e1ticamente el tr\u00e1fico pagado real desde GA4. Param: {draft_id, actual_metrics?}."
    },
    {
      "function_name": "exploreKeywordOpportunities",
      "description": "Investiga oportunidades de keywords reales (alta intenci\u00f3n, SEO/GEO, targeting) para anclar campa\u00f1as en demanda real."
    },
    {
      "function_name": "gaFetchRealtime",
      "description": "Trae m\u00e9tricas en tiempo real de Google Analytics 4 para cruzar el rendimiento del sitio con las campa\u00f1as y decidir hacia d\u00f3nde mandar el tr\u00e1fico pagado."
    },
    {
      "function_name": "syncToMerchantCenter",
      "description": "Empuja TODO el cat\u00e1logo de productos elegibles a Google Merchant Center y fuerza el crawl (Google ping + sitemap GSC + IndexNow). \u00dasalo cuando el cliente quiera optimizar/refrescar el feed para Performance Max o Shopping. Sin par\u00e1metros. Devuelve cu\u00e1ntos productos elegibles se enviaron."
    },
    {
      "function_name": "agentGenerateMedia",
      "description": "Genera una imagen o video corto con IA desde las FOTOS REALES de un producto PEYU, para usar como creativo en Performance Max o Demand Gen. Params: {tipo:'imagen'|'video', sku o producto (nombre), efecto (estilo libre), formato:'cuadrado'|'historia'|'horizontal', duracion:4|6|8 (solo video)}. Se guarda en Social Studio."
    }
