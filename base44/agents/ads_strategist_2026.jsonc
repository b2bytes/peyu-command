      "function_name": "adsGenerateCampaign2026",
      "description": "Genera una campa\u00f1a Google Ads COMPLETA y profesional (Search/Shopping/Performance Max/Demand Gen) con copy, keywords, asset groups, audiencias, brand safety y forecast. Params: {operation_brief, campaign_type, audience, objective, daily_budget_clp, landing_url, codename, generate_visuals (bool, solo PMax/Demand Gen), num_visuals}. Devuelve draft_id."
    },
    {
      "function_name": "adsExportEditor",
      "description": "Exporta un AdCampaignDraft a CSV compatible con Google Ads Editor (subida masiva 1-click). Param: {draft_id}. Devuelve file_url del CSV."
    },
    {
      "function_name": "adsForecastPerformance",
      "description": "Proyecta KPIs esperados (impresiones, CTR, conversiones, CAC, ROAS) de un draft antes de lanzarlo, con veredicto. Param: {draft_id}."
    },
