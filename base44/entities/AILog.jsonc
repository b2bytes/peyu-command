{
  "name": "AILog",
  "type": "object",
  "description": "Registro de cada llamada a un modelo IA (asistente, InvokeLLM, generaciones). Permite auditar respuestas, medir uso de tokens, costo, latencia y marcar casos para re-entrenamiento.",
  "properties": {
    "description": {
      "type": "string",
      "title": "Descripci\u00f3n",
      "maxLength": 1000
    },
    "agent_name": {
      "type": "string",
      "title": "Agente / funci\u00f3n origen",
      "description": "ej: asistente_compras, peyu, generateBlogPost, generateMockup, askPeyuBrain"
    },
    "model": {
      "type": "string",
      "title": "Modelo usado",
      "description": "ej: gpt-4o-mini, claude_sonnet_4_6, gemini_3_flash"
    },
    "task_type": {
      "type": "string",
      "title": "Tipo de tarea",
      "enum": [
        "chat",
        "blog_post",
        "mockup",
        "social_content",
        "ad_campaign",
        "lead_triage",
        "proposal",
        "brain_search",
        "summary",
        "review_analysis",
        "other"
      ]
    },
    "user_message": {
      "type": "string",
      "title": "Mensaje del usuario / prompt"
    },
    "system_context": {
      "type": "string",
      "title": "Contexto / system prompt (truncado)"
    },
    "ai_response": {
      "type": "string",
      "title": "Respuesta del modelo"
    },
    "session_id": {
      "type": "string",
      "title": "Session ID"
    },
    "conversation_id": {
      "type": "string",
      "title": "Conversation ID (Base44 agents)"
    },
    "user_email": {
      "type": "string",
      "title": "Email del usuario (si autenticado)"
    },
    "tokens_input": {
      "type": "number",
      "title": "Tokens entrada",
      "default": 0
    },
    "tokens_output": {
      "type": "number",
      "title": "Tokens salida",
      "default": 0
    },
    "tokens_total": {
      "type": "number",
      "title": "Tokens totales",
      "default": 0
    },
    "cost_usd": {
      "type": "number",
      "title": "Costo estimado (USD)",
      "default": 0
    },
    "latency_ms": {
      "type": "number",
      "title": "Latencia (ms)",
      "default": 0
    },
    "status": {
      "type": "string",
      "title": "Estado",
      "enum": [
        "success",
        "error",
        "timeout",
        "filtered",
        "fallback"
      ],
      "default": "success"
    },
    "error_message": {
      "type": "string",
      "title": "Mensaje de error (si aplica)"
    },
    "user_feedback": {
      "type": "string",
      "title": "Feedback del usuario",
      "enum": [
        "positive",
        "negative",
        "neutral",
        "none"
      ],
      "default": "none"
    },
    "auditor_review": {
      "type": "string",
      "title": "Revisi\u00f3n del auditor",
      "enum": [
        "pending",
        "approved",
        "flagged",
        "needs_retraining"
      ],
      "default": "pending"
    },
    "auditor_notes": {
      "type": "string",
      "title": "Notas del auditor"
    },
    "marked_for_retraining": {
      "type": "boolean",
      "title": "Marcado para re-entrenamiento",
      "default": false
    },
    "retraining_corrected_response": {
      "type": "string",
      "title": "Respuesta corregida (gold standard para fine-tuning)"
    },
    "retraining_status": {
      "type": "string",
      "title": "Estado del re-entrenamiento",
      "enum": [
        "none",
        "queued",
        "applied",
        "rejected"
      ],
      "default": "none"
    },
    "tags": {
      "type": "array",
      "title": "Tags",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "agent_name",
    "task_type"
  ]
}