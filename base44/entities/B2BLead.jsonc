{
  "name": "B2BLead",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "title": "Fuente",
      "enum": [
        "WhatsApp",
        "Formulario Web",
        "Email",
        "Instagram",
        "LinkedIn",
        "Referido",
        "Otro"
      ]
    },
    "contact_name": {
      "type": "string",
      "title": "Nombre Contacto"
    },
    "company_name": {
      "type": "string",
      "title": "Empresa"
    },
    "email": {
      "type": "string",
      "title": "Email"
    },
    "phone": {
      "type": "string",
      "title": "Tel\u00e9fono / WhatsApp"
    },
    "rut": {
      "type": "string",
      "title": "RUT Empresa"
    },
    "product_interest": {
      "type": "string",
      "title": "Producto de Inter\u00e9s"
    },
    "qty_estimate": {
      "type": "number",
      "title": "Cantidad Estimada (u)"
    },
    "delivery_date": {
      "type": "string",
      "title": "Fecha Requerida"
    },
    "personalization_needs": {
      "type": "boolean",
      "title": "Requiere Personalizaci\u00f3n UV"
    },
    "has_plastic": {
      "type": "boolean",
      "title": "Tiene Pl\u00e1stico para Reciclar"
    },
    "brief_url": {
      "type": "string",
      "title": "URL Brief / Archivo"
    },
    "logo_url": {
      "type": "string",
      "title": "URL Logo"
    },
    "lead_score": {
      "type": "number",
      "title": "Lead Score (0-100)"
    },
    "status": {
      "type": "string",
      "title": "Estado",
      "enum": [
        "Nuevo",
        "Contactado",
        "En revisi\u00f3n",
        "Propuesta enviada",
        "Aceptado",
        "Perdido"
      ]
    },
    "urgency": {
      "type": "string",
      "title": "Urgencia",
      "enum": [
        "Alta",
        "Normal",
        "Baja"
      ],
      "default": "Normal"
    },
    "notes": {
      "type": "string",
      "title": "Notas Internas"
    },
    "assigned_to": {
      "type": "string",
      "title": "Asignado a"
    },
    "utm_source": {
      "type": "string",
      "title": "UTM Source"
    },
    "mockup_urls": {
      "type": "array",
      "title": "URLs Mockups",
      "items": {
        "type": "string"
      }
    },
    "proposal_id": {
      "type": "string",
      "title": "ID Propuesta Vinculada"
    },
    "contact_history": {
      "type": "array",
      "title": "Historial de Contactos",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "channel": { "type": "string" },
          "note": { "type": "string" },
          "by": { "type": "string" }
        }
      }
    },
    "ai_recommendation": {
      "type": "string",
      "title": "Recomendacion IA"
    },
    "last_contact_date": {
      "type": "string",
      "title": "Fecha Ultimo Contacto"
    },
    "expected_close_date": {
      "type": "string",
      "title": "Fecha Estimada Cierre"
    },
    "deal_value": {
      "type": "number",
      "title": "Valor Estimado Deal ($)"
    }
  },
  "required": [
    "contact_name",
    "company_name",
    "source",
    "status"
  ]
}
